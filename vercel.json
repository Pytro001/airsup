{
  "outputDirectory": ".",
  "buildCommand": "cd server && npm install && npx tsc",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/internal/jobs",
      "schedule": "0 2 * * *"
    }
  ],
  "functions": {
    "api/index.ts": {
      "includeFiles": "server/dist/**,server/node_modules/**",
      "maxDuration": 30
    }
  },
  "redirects": [
    { "source": "/app", "destination": "/", "permanent": true },
    { "source": "/app/", "destination": "/", "permanent": true },
    { "source": "/dashboard", "destination": "/", "permanent": true },
    { "source": "/dashboard/", "destination": "/", "permanent": true },
    { "source": "/workspace", "destination": "/", "permanent": true },
    { "source": "/workspace/", "destination": "/", "permanent": true }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/webhooks/(.*)", "destination": "/api" },
    { "source": "/health", "destination": "/api" },
    { "source": "/admin", "destination": "/_app.html" },
    { "source": "/admin/", "destination": "/_app.html" },
    { "source": "/start", "destination": "/start.html" },
    { "source": "/start/", "destination": "/start.html" },
    { "source": "/landingpage", "destination": "/landingpage.html" },
    { "source": "/landingpage/", "destination": "/landingpage.html" },
    { "source": "/supi", "destination": "/supi.html" },
    { "source": "/supi/", "destination": "/supi.html" },
    { "source": "/support", "destination": "/support.html" },
    { "source": "/support/", "destination": "/support.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/privacy/", "destination": "/privacy.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/terms/", "destination": "/terms.html" },
    { "source": "/faq", "destination": "/faq.html" },
    { "source": "/faq/", "destination": "/faq.html" },
    { "source": "/", "destination": "/landingpage.html" }
  ]
}
