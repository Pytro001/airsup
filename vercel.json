{
  "outputDirectory": ".",
  "buildCommand": "cd server && npm install && npx tsc",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/internal/jobs",
      "schedule": "0 2 * * *"
    }
  ],
  "functions": {
    "api/index.ts": {
      "includeFiles": "server/dist/**,server/node_modules/**",
      "maxDuration": 30
    }
  },
  "redirects": [
    { "source": "/app", "destination": "/dashboard", "permanent": true },
    { "source": "/app/", "destination": "/dashboard", "permanent": true }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/webhooks/(.*)", "destination": "/api" },
    { "source": "/health", "destination": "/api" },
    { "source": "/admin", "destination": "/app.html" },
    { "source": "/admin/", "destination": "/app.html" },
    { "source": "/dashboard", "destination": "/app.html" },
    { "source": "/dashboard/", "destination": "/app.html" },
    { "source": "/landingpage", "destination": "/landingpage.html" },
    { "source": "/landingpage/", "destination": "/landingpage.html" },
    { "source": "/", "destination": "/landingpage.html" }
  ]
}
